{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research.opensourcemed.info/post-viral-illness.schema.json",
  "title": "PostViralIllnessPage",
  "description": "Curated, reference-backed record of post-viral / post-infectious illnesses and their current treatment options. Every reference must resolve to a real, published article, guideline, or authoritative clinical resource.",
  "type": "object",
  "required": ["schema_version", "slug", "title", "description", "last_updated", "disclaimer", "conditions"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "last_updated": { "type": "string", "format": "date" },
    "disclaimer": { "type": "string" },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/condition" }
    },
    "comparison": {
      "type": "object",
      "description": "Cross-condition analysis: shared-mechanism matrix and symptom-frequency matrix. Every populated cell must carry at least one reference_id resolving to a real reference (in comparison.references or any condition's references). Cells with no located evidence use strength/level 'insufficient_data' and no reference.",
      "required": ["symptom_axes", "mechanism_axes", "symptom_matrix", "mechanism_matrix", "references"],
      "properties": {
        "note": { "type": "string" },
        "symptom_axes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": { "id": { "type": "string" }, "label": { "type": "string" } }
          }
        },
        "mechanism_axes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "symptom_matrix": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["condition_id", "cells"],
            "properties": {
              "condition_id": { "type": "string" },
              "cells": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["axis_id", "level"],
                  "properties": {
                    "axis_id": { "type": "string" },
                    "level": {
                      "type": "string",
                      "enum": ["defining", "high", "moderate", "reported", "insufficient_data"]
                    },
                    "display": { "type": "string", "description": "Human-readable value, e.g. '≈88%', '55–89%', 'defining feature'." },
                    "note": { "type": ["string", "null"] },
                    "reference_ids": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        },
        "mechanism_matrix": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["condition_id", "cells"],
            "properties": {
              "condition_id": { "type": "string" },
              "cells": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["axis_id", "evidence_strength"],
                  "properties": {
                    "axis_id": { "type": "string" },
                    "evidence_strength": {
                      "type": "string",
                      "enum": ["established", "emerging", "hypothesized", "not_applicable", "insufficient_data"]
                    },
                    "note": { "type": ["string", "null"] },
                    "reference_ids": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        },
        "references": {
          "type": "array",
          "items": { "$ref": "#/$defs/reference" }
        }
      }
    }
  },
  "$defs": {
    "condition": {
      "type": "object",
      "required": ["id", "name", "trigger_pathogens", "overview", "treatments", "references"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "aka": { "type": "array", "items": { "type": "string" } },
        "trigger_pathogens": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Infectious triggers (e.g., SARS-CoV-2, dengue virus, poliovirus)."
        },
        "typical_onset": { "type": "string" },
        "overview": { "type": "string" },
        "core_features": { "type": "array", "items": { "type": "string" } },
        "epidemiology": { "type": ["string", "null"] },
        "mechanisms": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Leading pathophysiologic hypotheses (may be unproven)."
        },
        "diagnosis": { "type": ["string", "null"] },
        "treatments": {
          "type": "array",
          "items": { "$ref": "#/$defs/treatment" }
        },
        "references": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reference" }
        }
      }
    },
    "treatment": {
      "type": "object",
      "required": ["name", "category", "evidence_level", "status", "summary", "reference_ids"],
      "properties": {
        "name": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["supportive", "rehabilitative", "pharmacologic", "immunomodulatory", "disease_modifying", "preventive", "procedural"]
        },
        "evidence_level": {
          "type": "string",
          "enum": [
            "systematic_review_or_meta_analysis",
            "randomized_controlled_trial",
            "prospective_cohort",
            "case_series_or_observational",
            "expert_consensus_or_guideline",
            "no_proven_disease_specific_therapy"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["recommended", "reasonable_option", "investigational", "mixed_or_uncertain", "not_recommended"]
        },
        "summary": { "type": "string" },
        "reference_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of entries in the parent condition's references array."
        }
      }
    },
    "reference": {
      "type": "object",
      "required": ["id", "title", "source", "url", "type"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "authors": { "type": ["string", "null"] },
        "source": { "type": "string", "description": "Journal or publishing organization." },
        "year": { "type": ["integer", "null"] },
        "type": {
          "type": "string",
          "enum": ["systematic_review", "meta_analysis", "randomized_controlled_trial", "cohort_study", "case_control_study", "case_series", "clinical_guideline", "narrative_review", "government_or_agency_resource"]
        },
        "url": { "type": "string", "format": "uri" },
        "pmid": { "type": ["string", "null"] },
        "doi": { "type": ["string", "null"] }
      }
    }
  }
}
