    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Is there a validated diagnostic biomarker for Gulf War Illness?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. A 2021 systematic review found no single validated diagnostic biomarker for GWI. Chronic inflammation, homocysteine, IFN-γ, and cholinergic autoantibodies are recurring research findings."
          }
        },
        {
          "@type": "Question",
          "name": "What exposures are linked to Gulf War Illness biomarker research?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "GWI research examines pesticide exposures, pyridostigmine bromide, oil well fire smoke, depleted uranium, and multiple vaccinations."
          }
        }
      ]
    }
  ]
}